# Workspace path configuration
# Main checkout root for all thesis repos.
MIR_DATA_ROOT=/path/to/msc-thesis/repos/mir-data
MIR_OUTPUTS_ROOT=/path/to/msc-thesis/repos/mir-outputs
MIR_CORE_PATH=/path/to/msc-thesis/repos/mir-core

# MinIO / DVC configuration
# Used by setup-dvc.sh to configure mir-data and mir-outputs remotes.
MINIO_ENDPOINT=https://minio-api.thesis.hashimkarim.com
AWS_ACCESS_KEY_ID=your-minio-access-key
AWS_SECRET_ACCESS_KEY=your-minio-secret-key
