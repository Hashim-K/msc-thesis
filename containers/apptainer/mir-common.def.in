Bootstrap: docker
From: ubuntu:22.04

%setup
    mkdir -p "${APPTAINER_ROOTFS}/opt/msc-thesis"
    cp "__ENV_FILE__" "${APPTAINER_ROOTFS}/opt/msc-thesis/environment-apptainer.yml"
    mkdir -p "${APPTAINER_ROOTFS}/opt/msc-thesis/repos"
    cp -a "__MIR_CORE__" "${APPTAINER_ROOTFS}/opt/msc-thesis/repos/mir-core"

%labels
    Author Hashim Karim
    Description Common MIR runtime for DAIC and DelftBlue

%help
    Common Apptainer runtime for the MSc thesis MIR stack.
    Build with:
      ./scripts/apptainer/build.sh
    Run with:
      ./scripts/apptainer/exec.sh python -m mir_env.verify_installation

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        bzip2 \
        ca-certificates \
        curl \
        ffmpeg \
        git \
        libsndfile1 \
        build-essential
    rm -rf /var/lib/apt/lists/*

    curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/latest | tar -xj -C /usr/local/bin --strip-components=1 bin/micromamba

    mkdir -p /opt/msc-thesis/tmp /opt/msc-thesis/pip-cache
    export TMPDIR=/opt/msc-thesis/tmp
    export TEMP=/opt/msc-thesis/tmp
    export TMP=/opt/msc-thesis/tmp
    export PIP_CACHE_DIR=/opt/msc-thesis/pip-cache
    export PIP_NO_CACHE_DIR=1

    export MAMBA_ROOT_PREFIX=/opt/micromamba
    micromamba create -y -n MIR-apptainer -f /opt/msc-thesis/environment-apptainer.yml

    eval "$(micromamba shell hook -s bash)"
    micromamba activate MIR-apptainer

    python -m pip install -e /opt/msc-thesis/repos/mir-core

    micromamba clean -a -y
    rm -rf /opt/msc-thesis/tmp /opt/msc-thesis/pip-cache
    python -m pip cache purge || true

%environment
    export MAMBA_ROOT_PREFIX=/opt/micromamba
    export PATH=/opt/micromamba/envs/MIR-apptainer/bin:$PATH
    export CONDA_DEFAULT_ENV=MIR-apptainer
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    export MAMBA_ROOT_PREFIX=/opt/micromamba
    export PATH=/opt/micromamba/envs/MIR-apptainer/bin:$PATH
    if [ $# -eq 0 ]; then
        exec bash
    fi
    exec "$@"
